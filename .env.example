# ════════════════════════════════════════════════════════════
#  QuantAI Platform — Environment Variables
#  Copy to .env and fill in your values
# ════════════════════════════════════════════════════════════

# ── Application ──────────────────────────────────────────────
APP_NAME="QuantAI Platform"
APP_VERSION="1.0.0"
ENVIRONMENT=development
DEBUG=true
SECRET_KEY=your-super-secret-key-change-this-in-production-min-32-chars

# ── Database ─────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://quantai:quantai_secret@localhost:5432/quantai_db
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

# ── Redis ────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
REDIS_CACHE_TTL=3600

# ── Market Data APIs ─────────────────────────────────────────
# Free tier available at: https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_key

# Free tier at: https://polygon.io/
POLYGON_API_KEY=your_polygon_key

# Free tier at: https://api.tiingo.com/
TIINGO_API_KEY=your_tiingo_key

# Free at: https://newsapi.org/register
NEWS_API_KEY=your_news_api_key

# Free at: https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=your_fred_api_key

# ── AI APIs ──────────────────────────────────────────────────
OPENAI_API_KEY=your_openai_api_key
ANTHROPIC_API_KEY=your_anthropic_api_key

# ── MLflow ───────────────────────────────────────────────────
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_EXPERIMENT_NAME=quantai-experiments

# ── Celery ───────────────────────────────────────────────────
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ── CORS ─────────────────────────────────────────────────────
BACKEND_CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]
